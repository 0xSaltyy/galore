# Discord bot and guild
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# Discord OAuth for /admin
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/discord/callback

# Discord webhooks
DISCORD_STAFF_WEBHOOK_URL=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Recommended app config
SESSION_SECRET=replace-with-a-long-random-string-at-least-32-chars
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DISCORD_INVITE_URL=https://discord.gg/your-invite-code

# Comma-separated allowlists for /admin
DISCORD_ALLOWED_USER_IDS=your-discord-user-id
DISCORD_STAFF_ROLE_IDS=your-discord-staff-role-id

# Optional. Enable these only if the matching privileged intents are enabled in the Discord Developer Portal.
DISCORD_ENABLE_GUILD_MEMBERS_INTENT=false
DISCORD_ENABLE_PRESENCE_INTENT=false
